{
  "manifest_version": 3,
  "name": "SculptEQ",
  "version": "0.1.0",
  "description": "16-band parametric EQ + compressor for streaming services",
  "permissions": [
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SculptEQ EQ",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://music.youtube.com/*",
        "https://open.spotify.com/*",
        "https://music.apple.com/*",
        "https://listen.tidal.com/*"
      ],
      "js": [
        "content-dsp.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://music.youtube.com/*",
        "https://open.spotify.com/*",
        "https://music.apple.com/*",
        "https://listen.tidal.com/*"
      ],
      "js": [
        "content-bridge.js"
      ],
      "run_at": "document_start"
    }
  ],
  "key": ""
}